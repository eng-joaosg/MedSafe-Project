# =============================
# AMBIENTE
# =============================
NODE_ENV=development
PORT=3003

# =============================
# DATABASE SERVICE (COMUNICAÇÃO TCP)
# =============================
DATABASE_SERVICE_TCP_HOST=localhost
DATABASE_SERVICE_TCP_PORT=4000

# ========================================================
# 🔐 SEGURANÇA E AUTENTICAÇÃO
# ========================================================

DATABASE_X_NOTIFICATION_SERVICE_API_KEY=changeme_notification_key
DATABASE_X_AUTH_API_KEY=supersecret

# =============================
# LOGS E OBSERVABILIDADE
# =============================
LOG_LEVEL=debug
ENABLE_FILE_LOGS=false
LOG_FILE_PATH=./logs/notification-service.log

# =============================
# CORS 
# =============================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3004

# =============================
# HEALTH CHECK E METRICS
# =============================
HEALTH_CHECK_PATH=/health
METRICS_PATH=/metrics