# =============================
# AMBIENTE E SERVIDOR
# =============================
NODE_ENV=development
PORT=3004
API_VERSION=v1

# =============================
# DATABASE SERVICE
# =============================
DATABASE_SERVICE_TCP_HOST=localhost
DATABASE_X_CLINICAL_INFO_SERVICE_API_KEY=changeme_clinical_info_key

# =============================
# SEGURANÇA E AUTENTICAÇÃO
# =============================
CLINICAL_INFO_SERVICE_API_KEY=clinical-info-service-api-key-xyz123
JWT_SECRET=myjwtsecretkeyexample123
JWT_EXPIRATION_TIME=3600s

# =============================
# CORS (ORIGENS PERMITIDAS)
# =============================
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3005

# =============================
# LOGS E OBSERVABILIDADE
# =============================
LOG_LEVEL=debug
ENABLE_FILE_LOGS=false
LOG_FILE_PATH=./logs/clinical-info-service.log

# =============================
# HEALTH CHECK E METRICS
# =============================
HEALTH_CHECK_PATH=/health
METRICS_PATH=/metrics
