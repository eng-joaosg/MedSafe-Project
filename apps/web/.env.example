# ===========================================
# 🌎 AMBIENTE E CONFIGURAÇÕES GERAIS
# ===========================================
# 'development' | 'staging' | 'production'
NEXT_PUBLIC_APP_ENV=development

# URL base da API Gateway
NEXT_PUBLIC_API_BASE_URL=https://localhost/3001

# Nome do app exibido no título / metadados
NEXT_PUBLIC_APP_NAME=MedSafe

# ===========================================
# 🔐 AUTENTICAÇÃO (COGNITO)
# ===========================================
# Região do Cognito (ex: us-east-1)
NEXT_PUBLIC_AUTH_REGION=us-east-1

# ID do User Pool Cognito
NEXT_PUBLIC_AUTH_USER_POOL_ID=your_user_pool_id

# ID do App Client Cognito
NEXT_PUBLIC_AUTH_CLIENT_ID=your_client_id

# URL base do provedor Cognito
NEXT_PUBLIC_AUTH_PROVIDER=cognito

# ===========================================
# 💬 ENDPOINTS DO API GATEWAY
# ===========================================
# Normalmente o front só precisa da base, mas se quiser granularidade:
NEXT_PUBLIC_API_AUTH_URL=${NEXT_PUBLIC_API_BASE_URL}/auth
NEXT_PUBLIC_API_CLIENT_USER_URL=${NEXT_PUBLIC_API_BASE_URL}/client-user
NEXT_PUBLIC_API_MEDICAL_URL=${NEXT_PUBLIC_API_BASE_URL}/clinical-info

# ===========================================
# 📊 ANALYTICS / MONITORAMENTO
# ===========================================
# Sentry DSN
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics Measurement ID (ex: G-XXXXXXX)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=

# ===========================================
# ⚙️ OPCIONAIS / OUTROS SERVIÇOS
# ===========================================
# Chave pública para criptografia (se usada)
NEXT_PUBLIC_APP_PUBLIC_KEY=

# URL do site
NEXT_PUBLIC_APP_URL=https://your-frontend.vercel.app
