# Imagem base
FROM node:20-alpine

# Diretório de trabalho
WORKDIR /app

# Copiar package.json e instalar dependências
COPY package*.json ./
RUN npm ci

# Copiar todo o código da aplicação
COPY . .

# Porta que o container vai expor (pode ser sobrescrita pelo ambiente)
EXPOSE 443

# Comando de inicialização da aplicação
# A aplicação deve usar process.env para pegar todas as variáveis
CMD ["npm", "start"]
