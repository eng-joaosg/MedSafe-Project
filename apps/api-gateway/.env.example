# ========================================================
# 🌐 API GATEWAY CONFIGURATION
# ========================================================
API_VERSION=1.0
# Porta de execução da API Gateway
PORT=3001

# Ambiente de execução (development | staging | production)
NODE_ENV=development

# Nome do serviço (usado nos logs)
SERVICE_NAME=api-gateway

# ========================================================
# 🔑 AUTHENTICATION KEYS
# ========================================================

# Chave de autenticação para comunicações internas entre microsserviços
AUTH_SERVICE_API_KEY=supersecret
MEDICALINFO_SERVICE_APIKey=supersecret
JWT_SECRET=mySuperSecretKey
# ========================================================
# 🧩 SERVICES ENDPOINTS
# ========================================================

AUTH_SERVICE_URL=http://auth-service:3002
DATABASE_SERVICE_URL=http://database-service:3003
NOTIFICATION_SERVICE_URL=http://notification-service:3004
MEDICALINFO_SERVICE_URL=http://medicalinfo-service:3005

# ========================================================
# 🩺 HEALTH CHECK
# ========================================================

# Intervalo (em segundos) para checagem dos serviços
HEALTH_CHECK_INTERVAL=30

# ========================================================
# ⚙️ LOGGING
# ========================================================

# Nível de log (error | warn | info | debug)
LOG_LEVEL=info

# Caminho opcional para logs persistentes (em produção)
LOG_FILE_PATH=./logs/gateway.log

# ========================================================
# 🧠 SYSTEM
# ========================================================

HTTP_TIMEOUT=5000
HTTP_KEEP_ALIVE=10000
HTTP_MAX_REDIRECTS=5

