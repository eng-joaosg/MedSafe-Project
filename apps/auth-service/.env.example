# ========================================================
# ⚙️ AMBIENTE E SERVIDOR
# ========================================================

# Ambiente da aplicação (development | staging | production)
NODE_ENV=development

# Porta do Auth Service
PORT=3002

# Nome do serviço (usado nos logs e nas comunicações)
SERVICE_NAME=auth-service

# ========================================================
# 🗄️ INTEGRAÇÃO COM DATABASE SERVICE
# ========================================================

# URL interna do microserviço de banco de dados
DATABASE_SERVICE_URL=http://localhost:3003

# Chave de autenticação enviada para o Database Service
DATABASE_X_AUTH_API_KEY=supersecret

# Timeout para chamadas ao Database Service (em ms)
DATABASE_SERVICE_TIMEOUT=5000

# ========================================================
# 🔐 SEGURANÇA E AUTENTICAÇÃO
# ========================================================

# Chave secreta para geração de tokens JWT
JWT_SECRET=myjwtsecretkeyexample123

# Tempo de expiração dos tokens JWT (ex: 3600s, 15m, 7d)
JWT_EXPIRATION_TIME=3600s

# Número de rounds usados no bcrypt (hash de senhas)
HASH_SALT_ROUNDS=10

# API Key privada usada para validar requisições internas (ex: chamadas do API Gateway)
AUTH_SERVICE_API_KEY=supersecret

# ========================================================
# 🌐 CORS
# ========================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001http://localhost:3004,http://localhost:3005

# ========================================================
# 📬 AWS SQS (MENSAGERIA)
# ========================================================

# Região AWS usada pelo SQS
AWS_REGION=us-east-1

# Credenciais ==
AWS_ACCESS_KEY_ID=EXAMPLEAWSACCESSKEYID12345
AWS_SECRET_ACCESS_KEY=EXAMPLEAWSSECRETACCESSKEY67890

# URL completa da fila SQS usada para eventos do Auth Service
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/auth-queue

# Tempo de espera de polling (em segundos) para leitura de mensagens
SQS_POLL_INTERVAL=10

# ========================================================
# 🧾 LOGGING E MONITORAMENTO
# ========================================================

# Nível de log (error | warn | info | debug)
LOG_LEVEL=info

# Caminho opcional de arquivo de log (em produção)
LOG_FILE_PATH=./logs/auth-service.log

# ========================================================
# 🧠 SISTEMA E PERFORMANCE
# ========================================================

# Timeout padrão de requisições HTTP (em ms)
HTTP_TIMEOUT=5000

# Keep-alive para conexões HTTP (em ms)
HTTP_KEEP_ALIVE=10000
